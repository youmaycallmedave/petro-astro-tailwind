---
const faqs = [
  {
    question: "What ports are open by default on my VPS?",
    answer: "By default, all ports are open on your VPS. You have full control over your firewall settings and can configure port access based on your specific requirements. Common ports like 22 (SSH), 80 (HTTP), and 443 (HTTPS) are accessible right out of the box.",
  },
  {
    question: "Is there any possibility to change the IP Address of my VPS?",
    answer: "Yes, you can request an IP address change through your control panel. Additional IP addresses are available for a small monthly fee. Please note that changing your primary IP may require a brief maintenance window to update DNS records.",
  },
  {
    question: "What operating systems are available at PetroSky?",
    answer: "We support a wide range of operating systems including Ubuntu, Debian, CentOS, AlmaLinux, Rocky Linux, Fedora, and Windows Server. You can reinstall your OS at any time from the control panel, and custom ISO uploads are also supported.",
  },
  {
    question: "Can I get a refund if it doesn't work for my needs?",
    answer: "We offer a 7-day money-back guarantee for all new customers. If you're not satisfied with our service within the first 7 days, contact our support team and we'll process a full refund. After this period, refunds are handled on a case-by-case basis.",
  },
  {
    question: "Is your hosting DMCA-Ignored?",
    answer: "Our infrastructure is hosted in jurisdictions with flexible DMCA policies, providing you with greater freedom for your projects. However, we do not support illegal activities and reserve the right to suspend accounts that violate our terms of service.",
  },
]
---

<section class="bg-[#0d0e0f] flex flex-col items-center py-32 w-full">

  <!-- Заголовок -->
  <div class="flex items-end justify-between pb-16 px-5 w-full max-w-[1512px]">
    <div class="flex flex-col gap-8 items-start">
      <div class="flex items-center gap-2 bg-[#397dfe] px-2 h-7">
        <div class="size-2 bg-[#f5f6f9] shrink-0"></div>
        <span class="text-[#f5f6f9] text-sm font-medium tracking-[-0.14px] whitespace-nowrap">FAQ</span>
      </div>
      <h2 class="text-[56px] font-medium leading-none tracking-[-0.56px] text-[#f5f6f9] max-w-[602px]">
        Frequently Asked Questions
      </h2>
    </div>
  </div>

  <!-- FAQ список -->
  <div class="flex flex-col gap-6 items-start px-5 w-full max-w-[1512px]">

    <p class="text-[#f5f6f9] text-sm font-medium tracking-[-0.14px]">[ 01  /  {faqs.length.toString().padStart(2, '0')} ]</p>

    <div class="flex flex-col items-center w-full">
      <div class="w-full border-t border-dashed border-[#252526]"></div>

      <div class="flex flex-col w-full max-w-[726px]">
        {faqs.map((faq, i) => (
          <div class={`faq-item ${i < faqs.length - 1 ? 'border-b border-dashed border-[#252526]' : ''}`}>
            <button
              class="faq-trigger flex items-center justify-between w-full py-6 text-left cursor-pointer"
              aria-expanded="false"
              data-index={i}
            >
              <p class="text-[#f5f6f9] text-2xl font-medium leading-none tracking-[-0.24px] max-w-[630px]">
                {faq.question}
              </p>
              <div class="bg-[#397dfe] flex items-center justify-center p-1 size-7 shrink-0 ml-4">
                <svg
                  class="faq-chevron transition-transform duration-300"
                  width="20" height="20" viewBox="0 0 20 20"
                  fill="none" xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="#f5f6f9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </button>
            <div class="faq-body overflow-hidden" style="height: 0">
              <p class="text-[#808792] text-[20px] font-medium leading-[1.35] tracking-[-0.2px] pb-6">
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="w-full border-t border-dashed border-[#252526]"></div>
    </div>

  </div>

</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!
      const body = item.querySelector<HTMLElement>('.faq-body')!
      const chevron = btn.querySelector<SVGElement>('.faq-chevron')!
      const isOpen = btn.getAttribute('aria-expanded') === 'true'

      if (isOpen) {
        // закрыть
        body.style.height = body.scrollHeight + 'px'
        requestAnimationFrame(() => {
          body.style.transition = 'height 0.35s ease'
          body.style.height = '0'
        })
        chevron.style.transform = 'rotate(0deg)'
        btn.setAttribute('aria-expanded', 'false')
      } else {
        // открыть
        body.style.transition = 'height 0.35s ease'
        body.style.height = body.scrollHeight + 'px'
        body.addEventListener('transitionend', () => {
          body.style.height = 'auto'
        }, { once: true })
        chevron.style.transform = 'rotate(180deg)'
        btn.setAttribute('aria-expanded', 'true')
      }
    })
  })
</script>
