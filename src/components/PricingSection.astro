---
const plans = [
  {
    name: "Pro",
    price: "$8",
    dark: false,
    description: "Perfect for web hosting, APIs, VPNs, and production apps.",
    cpu: "1 vCPU",
    buttonLabel: "Deploy PRO",
    features: [
      { label: "AMD EPYC™ Gen 3/4", included: true },
      { label: "10Gbps Public Network", included: true },
      { label: "Ceph-Backed NVMe", included: true },
      { label: "Auto-Backups Available", included: true },
      { label: "Nested Virtualization", included: false },
      { label: "AMD SEV Encryption", included: false },
    ],
  },
  {
    name: "Pro+ Hybrid",
    price: "$24",
    dark: false,
    description: "For nested virtualization, Android emulators, and heavy compute.",
    cpu: "2 vCPU",
    buttonLabel: "Deploy PRO + HYBRID",
    features: [
      { label: "AMD EPYC™ High-Freq", included: true },
      { label: "Nested Virtualization (KVM)", included: true },
      { label: "40Gbps Private Fabric", included: true },
      { label: "Priority Support", included: true },
      { label: "Optional AMD SEV", included: true },
      { label: "Auto-Backups Available", included: true },
    ],
  },
  {
    name: "Enterprise",
    price: "Custom",
    priceRaw: true,
    dark: true,
    description: "For large deployments, private racks, and custom compliance.",
    cpu: null,
    buttonLabel: "Contact Sales",
    features: [
      { label: "AMD EPYC™ High-Freq", included: true },
      { label: "Nested Virtualization (KVM)", included: true },
      { label: "40Gbps Private Fabric", included: true },
      { label: "Priority Support", included: true },
      { label: "Optional AMD SEV", included: true },
      { label: "Auto-Backups Available", included: true },
    ],
  },
]
---

<section class="bg-[#0d0e0f] flex flex-col items-center py-16 md:py-32 w-full">

  <!-- Заголовок -->
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 pb-12 md:pb-20 px-5 w-full max-w-[1512px]">
    <div class="flex flex-col gap-6 md:gap-8 items-start">
      <div class="flex items-center gap-2 bg-[#397dfe] px-2 h-7">
        <div class="size-2 bg-[#f5f6f9] shrink-0"></div>
        <span class="text-[#f5f6f9] text-sm font-medium tracking-[-0.14px] whitespace-nowrap">Pricing</span>
      </div>
      <h2 class="text-[36px] md:text-[56px] font-medium leading-none tracking-[-0.56px] text-[#f5f6f9]">
        Transparent,<br />Predictable Pricing.
      </h2>
    </div>
    <div class="md:max-w-[353px]">
      <p class="text-[16px] md:text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9]">
        Designed for teams and developers who need consistent performance, low latency, and full infrastructure control.
      </p>
    </div>
  </div>

  <!-- Карты -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 px-5 w-full max-w-[1512px]">
    {plans.map((plan) => (
      <div class={`flex flex-col p-8 ${plan.dark ? 'bg-[#0d0e0f] border border-[#252526]' : 'bg-white'}`}>
        <div class="flex flex-col gap-5 flex-1">

          <!-- Название + цена -->
          <div class="flex items-center justify-between">
            <span class={`text-[36px] font-medium leading-none tracking-[-0.36px] ${plan.dark ? 'text-[#f5f6f9]' : 'text-[#0d0e0f]'}`}>
              {plan.name}
            </span>
            {plan.priceRaw ? (
              <span class="text-[36px] font-medium leading-none tracking-[-0.36px] text-[#397dfe]">{plan.price}</span>
            ) : (
              <span class="text-[#397dfe]">
                <span class="text-[16px] font-medium tracking-[-0.16px]">from </span>
                <span class="text-[36px] font-medium leading-none tracking-[-0.36px]">{plan.price}</span>
                <span class="text-[16px] font-medium tracking-[-0.16px]">/mo</span>
              </span>
            )}
          </div>

          <!-- Разделитель -->
          <div class={`w-full border-t ${plan.dark ? 'border-[#252526]' : 'border-[#e5e7eb]'}`}></div>

          <!-- Описание -->
          <p class={`text-[18px] font-medium leading-[1.35] tracking-[-0.18px] ${plan.dark ? 'text-[#f5f6f9]' : 'text-[#0d0e0f]'}`}>
            {plan.description}
          </p>

          <!-- Дропдаун CPU -->
          {plan.cpu && (
            <div class="flex items-center justify-between border border-[#397dfe] px-4 h-12">
              <span class="text-[18px] font-medium tracking-[-0.18px] text-[#397dfe]">{plan.cpu}</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke="#397dfe" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}

          <!-- Разделитель -->
          <div class={`w-full border-t border-dashed ${plan.dark ? 'border-[#252526]' : 'border-[#cccfd3]'}`}></div>

          <!-- Фичи -->
          <div class="flex flex-col gap-4 flex-1">
            <p class={`text-[20px] font-medium leading-[1.35] tracking-[-0.2px] ${plan.dark ? 'text-[#f5f6f9]' : 'text-[#0d0e0f]'}`}>
              Includes:
            </p>
            <div class="flex flex-col gap-4 py-2">
              {plan.features.map((f) => (
                <div class={`flex items-center gap-4 ${!f.included ? 'opacity-15' : ''}`}>
                  <div class="bg-[#397dfe] flex items-center justify-center size-6 shrink-0 p-1">
                    {f.included ? (
                      <!-- Checkmark -->
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 8L6.5 11.5L13 5" stroke="#f5f6f9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    ) : (
                      <!-- Cross -->
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 4L12 12M12 4L4 12" stroke="#f5f6f9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </div>
                  <span class={`text-[20px] font-medium leading-[1.35] tracking-[-0.2px] ${plan.dark ? 'text-[#f5f6f9]' : 'text-[#0d0e0f]'}`}>
                    {f.label}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <!-- Разделитель -->
          <div class={`w-full border-t border-dashed ${plan.dark ? 'border-[#252526]' : 'border-[#cccfd3]'}`}></div>

        </div>

        <!-- Кнопка -->
        <button class="w-full flex items-center justify-center gap-2 bg-[#397dfe] h-14 mt-5 cursor-pointer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 9l5 3.5L4 16M12 16h8" stroke="#f5f6f9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-[18px] font-medium tracking-[-0.18px] text-[#f5f6f9] whitespace-nowrap">{plan.buttonLabel}</span>
        </button>

      </div>
    ))}
  </div>

</section>
