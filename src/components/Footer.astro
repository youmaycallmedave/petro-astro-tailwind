---
const imgX = "https://www.figma.com/api/mcp/asset/2b2881dd-63bb-45f9-b7c1-3af35a7b373a"
const imgTelegram = "https://www.figma.com/api/mcp/asset/bbe9ef6e-699f-40c5-9794-a04530020dcc"
const imgDiscord = "https://www.figma.com/api/mcp/asset/4c94d22d-eaec-4dde-a982-bfa71df3fb7a"
const imgPayPal = "https://www.figma.com/api/mcp/asset/c4801c85-722f-4650-99e6-4226051eb5cd"
const imgBg = "https://www.figma.com/api/mcp/asset/52318bb3-471e-45db-a20b-65e431788c14"
const imgGlow = "https://www.figma.com/api/mcp/asset/95786b6e-dbd4-475d-8a9d-19ea832b657f"

const product = ['Features', 'Pricing Pro', 'Pricing Pro+Hybrid', 'Docs', 'Affiliate']
const company = ['About', 'Blog', 'Contact', 'Log In', 'Deploy']
const solutions = ['VPS Forex Trading', 'BlueStacks VPS', 'VPS For LDPlayer', 'VPS For Genymotion', 'VPS For NoxPlayer', 'VPS For App Testing']
const locations = ['USA VPS', 'Paris VPS', 'France VPS', 'Canada VPS', 'UK VPS']
---

<footer class="bg-[#0d0e0f] w-full relative overflow-hidden pt-16 pb-4 px-5">

  <!-- Background effect -->
  <div class="absolute top-[-44px] left-[432px] w-[1488px] h-[1125px] mix-blend-lighten opacity-54 rotate-[15deg] pointer-events-none">
    <img src={imgBg} alt="" class="w-full h-full object-cover" />
  </div>
  <!-- Glow ellipse -->
  <div class="absolute top-[-27px] left-[690px] size-[713px] pointer-events-none">
    <img src={imgGlow} alt="" class="w-full h-full object-contain" style="margin: -31.56%" />
  </div>

  <div class="relative z-10 w-full max-w-[1472px] mx-auto flex flex-col gap-[80px]">

    <!-- Main content -->
    <div class="flex flex-col lg:flex-row items-start justify-between gap-12">

      <!-- Left: contact + social + newsletter -->
      <div class="flex flex-col gap-16 shrink-0 w-full lg:w-[478px]">

        <!-- Addresses -->
        <div class="flex flex-col md:flex-row gap-6">
          <div class="flex flex-col gap-5 flex-1">
            <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Contact</p>
            <p class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9]">17192 Murphy Ave Unit 17275 Irvine, CA 92623</p>
          </div>
          <div class="flex flex-col gap-5 flex-1">
            <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase opacity-0 select-none">Contact</p>
            <p class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9]">North Gould St Ste r, 30 Sheridan, WY 82801</p>
          </div>
        </div>

        <!-- Social icons -->
        <div class="flex items-center gap-3">
          <a href="#" class="size-5 shrink-0">
            <img src={imgX} alt="X" class="size-full object-contain" />
          </a>
          <a href="#" class="size-5 shrink-0">
            <img src={imgTelegram} alt="Telegram" class="size-full object-contain" />
          </a>
          <a href="#" class="size-5 shrink-0">
            <img src={imgDiscord} alt="Discord" class="size-full object-contain" />
          </a>
        </div>

        <!-- Newsletter -->
        <div class="flex flex-col gap-3 w-full">
          <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Join our newsletter</p>
          <div class="border-b border-[#f5f6f9] flex items-end justify-between pb-4">
            <input
              type="email"
              placeholder="Your Email"
              class="bg-transparent text-[16px] font-medium tracking-[-0.16px] text-[#f5f6f9] placeholder-[#f5f6f9] outline-none flex-1"
            />
            <button class="bg-[#397dfe] flex items-center justify-center size-7 shrink-0">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="#f5f6f9" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

      </div>

      <!-- Right: nav columns -->
      <div class="flex flex-wrap gap-x-12 gap-y-10 lg:gap-x-16">

        <!-- Product -->
        <div class="flex flex-col gap-5">
          <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Product</p>
          <div class="flex flex-col gap-4">
            {product.map((item) => (
              <a href="#" class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9] hover:text-[#397dfe] transition-colors whitespace-nowrap">{item}</a>
            ))}
          </div>
        </div>

        <!-- Company -->
        <div class="flex flex-col gap-5">
          <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Company</p>
          <div class="flex flex-col gap-4">
            {company.map((item) => (
              <a href="#" class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9] hover:text-[#397dfe] transition-colors whitespace-nowrap">{item}</a>
            ))}
          </div>
        </div>

        <!-- Solutions -->
        <div class="flex flex-col gap-5">
          <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Solutions</p>
          <div class="flex flex-col gap-4">
            {solutions.map((item) => (
              <a href="#" class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9] hover:text-[#397dfe] transition-colors whitespace-nowrap">{item}</a>
            ))}
          </div>
        </div>

        <!-- Locations -->
        <div class="flex flex-col gap-5">
          <p class="text-[12px] font-medium tracking-[-0.12px] text-[#808792] uppercase">Locations</p>
          <div class="flex flex-col gap-4">
            {locations.map((item) => (
              <a href="#" class="text-[20px] font-medium leading-[1.35] tracking-[-0.2px] text-[#f5f6f9] hover:text-[#397dfe] transition-colors whitespace-nowrap">{item}</a>
            ))}
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#26292c] pt-4 flex flex-col md:flex-row items-center justify-between gap-4">

      <p class="text-[12px] font-medium tracking-[-0.12px] text-[#f5f6f9] whitespace-nowrap">©2026 Petrosky. All rights reserved.</p>

      <!-- Payment icons -->
      <div class="flex items-center gap-6">
        <img src={imgPayPal} alt="PayPal" class="h-5 w-auto max-w-[72px] object-contain shrink-0" />
        <!-- Credit card -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <rect x="2" y="5" width="20" height="14" rx="2" stroke="#f5f6f9" stroke-width="1.5"/>
          <path d="M2 10h20" stroke="#f5f6f9" stroke-width="1.5"/>
        </svg>
        <!-- Bitcoin -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14.5h-1v-1H9.5V9h2.5v-1H13V7h1v1h.5c1.1 0 2 .9 2 2v.5c0 .55-.45 1-1 1 .55 0 1 .45 1 1v.5c0 1.1-.9 2-2 2H14v1h-1v-1.5zm-2-6v2H13c.55 0 1-.45 1-1s-.45-1-1-1h-2zm0 3v2h2c.55 0 1-.45 1-1s-.45-1-1-1h-2z" fill="#f5f6f9"/>
        </svg>
      </div>

      <!-- Legal links -->
      <div class="flex items-center gap-12">
        <a href="#" class="text-[12px] font-medium tracking-[-0.12px] text-[#f5f6f9] underline whitespace-nowrap">Privacy Policy</a>
        <a href="#" class="text-[12px] font-medium tracking-[-0.12px] text-[#f5f6f9] underline whitespace-nowrap">Terms of Service</a>
      </div>

    </div>
  </div>

</footer>
